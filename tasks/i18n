# Extract translatable strings from templates and Python source into messages.pot
extract:
  #!/usr/bin/env sh
  cd {{justfile_directory()}}/src/backend
  uv run --group dev pybabel extract -F pyproject.toml -o app/locales/messages.pot --project="Field-TM" .

# Initialize a new locale (e.g. just i18n init fr)
init LOCALE:
  #!/usr/bin/env sh
  cd {{justfile_directory()}}/src/backend
  uv run --group dev pybabel init -i app/locales/messages.pot -d app/locales -l {{LOCALE}}

# Update existing .po files after re-extraction
update:
  #!/usr/bin/env sh
  cd {{justfile_directory()}}/src/backend
  uv run --group dev pybabel update -i app/locales/messages.pot -d app/locales

# Compile .po files into .mo files for runtime use
compile:
  #!/usr/bin/env sh
  cd {{justfile_directory()}}/src/backend
  uv run --group dev pybabel compile -d app/locales
