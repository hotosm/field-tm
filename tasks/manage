# List available commands
[private]
default:
  just --justfile {{justfile()}} --list manage

# Export bundled raw XLSForm templates to disk
[no-cd]
export-raw-xlsforms:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}/src/backend
  uv run python scripts/export_raw_xlsforms.py

# Rename docker volume
[no-cd]
rename-volume oldname newname:
  #!/usr/bin/env sh

  docker volume create {{newname}}

  docker run --rm \
    -i \
    -v {{oldname}}:/from \
    -v {{newname}}:/to \
    alpine ash -c "cd /from && cp -a . /to"

  echo ""
  echo "Renamed {{oldname}} to {{newname}}"
  echo "You can now safely delete {{oldname}}"

# Upgrade Postgres 14 --> 16 (local dev)
[no-cd]
upgrade-dev-db:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}

  just prep envsubst

  ./envsubst -i contrib/pg-upgrade/compose.yaml | \
    docker compose -f - up --abort-on-container-failure

# Upgrade Postgres 14 --> 16
[no-cd]
upgrade-db:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  export GIT_BRANCH=$(git symbolic-ref -q --short HEAD || git describe --tags --exact-match)

  # If branch is 'dev', override to 'development'
  if [ "$GIT_BRANCH" = "dev" ]; then
    GIT_BRANCH="development"
  fi

  just prep envsubst

  export VOLUME_NAME=field-tm-db-data-${GIT_BRANCH}

  ./envsubst -i contrib/pg-upgrade/compose.yaml | \
    docker compose -f - up --abort-on-container-failure
