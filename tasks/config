# Allow usage of nerdctl instead of docker
docker := env("DOCKER_ALIAS", "docker")

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list config

# Check if a dotenv variable is present
[no-cd]
[no-exit-message]
_dotenv-check key:
  #!/usr/bin/env sh
  if [ -z "${{ key }}" ]; then
      echo "Environment variable {{ key }} is not set."
      exit 1
  fi

# Update a variable in the .env file
[no-cd]
update-dotenv key value:
  #!/usr/bin/env sh

  var_name={{key}}
  var_value={{value}}
  var_pattern="^${var_name}="
  new_var="${var_name}=${var_value}"

  if grep -Eq "${var_pattern}" .env; then
    sed -i "s|${var_pattern}.*|${new_var}|" .env
  else
    echo "${new_var}" >> .env
  fi

# Generate the .env file from scratch, using .env.example and substitutions
[no-cd]
generate-dotenv branch="dev":
  #!/usr/bin/env sh
  set -e

  # By default we deploy from 'dev' branch, but can be overridden

  cd {{justfile_directory()}}
  just manage _install_envsubst

  if [ -f .env ]; then
    just _echo-yellow "'.env' already exists. Skipping generation."
  else
    # Generate a .env file from .env.example, substituting values from environment
    ./envsubst -i .env.example | grep -vE '^\s*#|^\s*$' > .env
  fi

  # Export all variables from .env into the environment
  if [ -f .env ]; then
    set -a
    . ./.env
    set +a
  fi

  # Generate compose file (default dev, but can be overridden)
  export GIT_BRANCH="{{ branch }}"
  echo ""
  just _echo-blue "Final compose file output for branch {{ branch }}:"
  echo ""
  # NOTE we run through envsubst twice for nested vars
  ./envsubst -i deploy/compose.sub.yaml | ./envsubst

# Interactive setup for production / self-hosted deployments
[no-cd]
setup:
  #!/usr/bin/env sh
  set -e

  cd {{justfile_directory()}}

  echo ""
  just _echo-blue "Field-TM Production Setup"
  just _echo-blue "========================="
  echo ""
  echo "This will generate a .env file and configure it for your domain."
  echo "Secrets and database passwords are auto-generated."
  echo ""

  # Remove existing .env so generate-dotenv creates a fresh one
  rm -f .env
  just config generate-dotenv > /dev/null 2>&1

  # --- Domain ---
  printf "Enter your domain (e.g. fieldtm.example.org): "
  read ftm_domain
  if [ -z "$ftm_domain" ]; then
    just _echo-red "Domain is required. Aborting."
    exit 1
  fi
  just config update-dotenv FTM_DOMAIN "$ftm_domain"
  just config update-dotenv HANKO_COOKIE_DOMAIN "$ftm_domain"
  just config update-dotenv HANKO_ALLOWED_ORIGIN "https://$ftm_domain"
  just config update-dotenv HANKO_REDIRECT_URL "https://$ftm_domain"

  # --- Cert email ---
  printf "Email for Let's Encrypt certificates: "
  read cert_email
  if [ -z "$cert_email" ]; then
    just _echo-red "Certificate email is required. Aborting."
    exit 1
  fi
  just config update-dotenv CERT_EMAIL "$cert_email"

  # --- Auth provider ---
  echo ""
  echo "Auth provider options:"
  echo "  1) bundled  - self-hosted Hanko (default, recommended)"
  echo "  2) hotosm   - centralised HOT login at login.hotosm.org"
  echo "  3) disabled - no authentication, public access"
  echo "  4) custom   - bring your own Hanko instance"
  printf "Select auth provider [1]: "
  read auth_choice
  case "$auth_choice" in
    2) just config update-dotenv AUTH_PROVIDER hotosm ;;
    3) just config update-dotenv AUTH_PROVIDER disabled ;;
    4) just config update-dotenv AUTH_PROVIDER custom ;;
    *) just config update-dotenv AUTH_PROVIDER bundled ;;
  esac

  # --- Auto-generate secrets & passwords ---
  just config update-dotenv ENCRYPTION_KEY "$(openssl rand -base64 32)"
  just config update-dotenv HANKO_SECRET "$(openssl rand -base64 32)"
  just config update-dotenv FTM_DB_PASSWORD "$(openssl rand -base64 24)"
  just config update-dotenv ODK_CENTRAL_PASSWD "$(openssl rand -base64 24)"
  just config update-dotenv QFIELDCLOUD_PASSWORD "$(openssl rand -base64 24)"
  just config update-dotenv QFIELDCLOUD_ADMIN_PASSWORD "$(openssl rand -base64 24)"

  echo ""
  just _echo-blue "Setup complete. Config written to .env"
  echo ""
  just _echo-yellow "Modify .env as needed, then run: just start prod       (or just start prod-login)"
  echo ""

# For custom branding, place favicon.svg in the repo root, then run this
[no-cd]
custom-favicon:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}

  # Copy favicon to required directories, if present
  if [ ! -f favicon.svg ]; then
    just _echo-yellow "'favicon.svg' not found in the repo root. Skipping custom favicon injection."
    exit 0
  fi

  echo ""
  echo "Found favicon.svg in repo root - bundling in backend static assets"
  echo ""
  # Pull ImageMagick container if not already present
  {{docker}} pull dpokidov/imagemagick:7.1.1-47

  # Convert SVG to PNG (32x32, aspect ratio preserved, transparent padding)
  {{docker}} run --rm -v "$PWD":/repo --workdir /repo --entrypoint=/bin/sh \
      dpokidov/imagemagick:7.1.1-47 \
      -c "magick favicon.svg -resize 32x32 -background none -gravity center -extent 32x32 favicon.png"

  # Copy to backend static icons
  cp favicon.svg src/backend/app/static/icons/favicon.svg
  cp favicon.png src/backend/app/static/icons/favicon.png

  # Then prevent tracking of the changes once overridden
  git update-index --assume-unchanged src/backend/app/static/icons/favicon.svg
  git update-index --assume-unchanged src/backend/app/static/icons/favicon.png

  just _echo-blue "Successfully added custom favicon.svg and favicon.png to backend static icons"

# Merge in translations from weblate
[no-cd]
merge-translations:
  git remote add weblate https://hosted.weblate.org/git/hotosm/field-tm-mapper-ui || true
  git fetch weblate
  git merge weblate/dev
