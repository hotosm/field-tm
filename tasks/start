# Allow usage of nerdctl instead of docker
docker := env("DOCKER_ALIAS", "docker")

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list start

# Start Field-TM (auth disabled)
[no-cd]
dev:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  AUTH_PROVIDER=disabled {{docker}} compose up -d

# Production deploy, based on current checked out branch
[no-cd]
prod:
  #!/usr/bin/env sh
  set -e

  # From deploy dir
  cd {{justfile_directory()}}/deploy
  export GIT_BRANCH=$(git symbolic-ref -q --short HEAD || git describe --tags --exact-match)
  just _echo-blue "Current branch: ${GIT_BRANCH}"

  # Config
  just config generate-dotenv "${GIT_BRANCH}"
  just config custom-favicon

  # Deploy core FieldTM
  ../envsubst -no-unset -i compose.sub.yaml | \
        {{docker}} compose -f - up --detach \
        --remove-orphans --force-recreate

  just _echo-blue "FieldTM started successfully"

# Production deploy with self-hosted Hanko auth (contrib/login)
[no-cd]
prod-login:
  #!/usr/bin/env sh
  set -e

  # From deploy dir
  cd {{justfile_directory()}}/deploy
  export GIT_BRANCH=$(git symbolic-ref -q --short HEAD || git describe --tags --exact-match)
  just _echo-blue "Current branch: ${GIT_BRANCH}"

  # Config
  just config generate-dotenv "${GIT_BRANCH}"
  just config custom-favicon

  # Both compose files use ${FTM_DOMAIN} in bunkerweb env var KEY names, which
  # requires envsubst preprocessing.  Process to temp files then compose together.
  tmp_main=$(mktemp)
  tmp_login=$(mktemp)
  ../envsubst -no-unset -i compose.sub.yaml > "$tmp_main"
  ../envsubst -no-unset -i compose.login.yaml > "$tmp_login"
  {{docker}} compose -f "$tmp_main" -f "$tmp_login" up --detach \
    --remove-orphans --force-recreate
  rm -f "$tmp_main" "$tmp_login"

  just _echo-blue "FieldTM + self-hosted Hanko started successfully"

# Production deploy with self-hosted ODK Central
[no-cd]
prod-with-odk:
  #!/usr/bin/env sh
  set -e

  # From deploy dir
  cd {{justfile_directory()}}/deploy
  export GIT_BRANCH=$(git symbolic-ref -q --short HEAD || git describe --tags --exact-match)
  just _echo-blue "Current branch: ${GIT_BRANCH}"

  # Config
  just config generate-dotenv "${GIT_BRANCH}"
  just config custom-favicon

  # Deploy core FieldTM + ODK Central addon
  ../envsubst -no-unset -i compose.sub.yaml | \
        {{docker}} compose -f - -f compose.odk.yaml up --detach \
        --remove-orphans --force-recreate

  just _echo-blue "FieldTM + ODK Central started successfully"

# Start backend API only
[no-cd]
backend:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose up -d backend

# Start backend API without docker
[no-cd]
backend-no-docker:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}/src/backend

  uv run --group dev pybabel compile -d app/locales

  FTM_DOMAIN="" OSM_CLIENT_ID="" OSM_CLIENT_SECRET="" \
  OSM_SECRET_KEY="" ENCRYPTION_KEY="" \
    uv run uvicorn app.main:api --host 0.0.0.0 --port 8000

# Start Field-TM without ODK Central
[no-cd]
without-central:
  {{docker}} compose --profile no-odk up -d

# Start Field-TM with self-hosted Hanko auth (contrib/login)
[no-cd]
login:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}

  {{docker}} compose \
    -f compose.yaml \
    -f contrib/login/compose.yaml \
    up -d

  echo
  echo "\033[0;33m ############################################### \033[0m"
  echo
  echo " Self-hosted Hanko is running."
  echo
  echo " HANKO_API_URL and HANKO_PUBLIC_URL are injected automatically."
  echo " No .env changes needed for local dev."
  echo
  echo " Captured emails (OTP passcodes): http://mail.field.localhost:${FTM_DEV_PORT:-7050}"
  echo " Login UI:                        http://login.field.localhost:${FTM_DEV_PORT:-7050}"
  echo
  echo "\033[0;33m ############################################### \033[0m"
  echo

