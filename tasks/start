# Externally accessible ODK Central & QFieldCloud for tests
[no-cd]
tunnel:
  #!/usr/bin/env sh

  {{docker}} compose \
    -f compose.yaml \
    -f contrib/tunnel/compose.yaml \
    up --wait

  # Workaround to until PR merged:
  # https://github.com/cloudflare/cloudflared/pull/1135
  # Wait until services ready without HEALTHCHECK
  sleep 5

  odk_url=$(just start _get-tunnel-url 'central')

  just start _restart-central-with-tunnel-domain "$odk_url"

  just start _print-tunnel-url "$odk_url"

# View the URLs for created tunnels
[no-cd]
view-tunnel-url:
  #!/usr/bin/env sh

  odk_url=$(just start _get-tunnel-url 'central')
  just start _print-tunnel-url "$odk_url"

# Restart ODK Central with the public tunnel hostname as DOMAIN (no port).
# Used by `just start tunnel` and `just test odk-collect`.
[no-cd]
_restart-central-with-tunnel-domain url:
  #!/usr/bin/env sh

  # FTM_CENTRAL_DOMAIN = hostname only (no port).
  # HTTPS is implied by the tunnel so omitting :443 keeps generated URLs clean.
  # We do NOT touch FTM_DEV_PORT here; that controls the proxy host-port binding
  # and must stay at its local value (port 443 is already owned by the tunnel container).
  FTM_CENTRAL_DOMAIN="$(echo "{{ url }}" | sed -E 's|^https://([^/:]+).*$|\1|')" \
  {{docker}} compose \
    -f compose.yaml \
    -f contrib/tunnel/compose.yaml \
    up -d --wait --force-recreate central

[no-cd]
_get-tunnel-url service_name:
  #!/usr/bin/env sh

  service_url=$({{docker}} compose \
    -f compose.yaml \
    -f contrib/tunnel/compose.yaml \
    logs {{service_name}}-tunnel | \
    grep 'Your quick Tunnel' -A 1 | tail -n 1 | \
    sed -n 's/.*| *\(https:\/\/[^ ]*\).*/\1/p')

  echo "$service_url"

[no-cd]
_print-tunnel-url odk_url:
  @echo
  @echo "\033[0;33m ############################################### \033[0m"
  @echo
  @echo "\033[0;34m ODK Central URL: \033[0m"
  @echo " {{odk_url}}"
  @echo
  @echo "\033[0;33m ############################################### \033[0m"
  @echo
