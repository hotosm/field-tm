docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list stop

# Stop Field-TM
[no-cd]
all:
  {{docker}} compose down

# Stop Field-TM & login service
[no-cd]
login:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}

  {{docker}} compose \
    -f compose.yaml \
    -f contrib/login/compose.yaml \
    down --remove-orphans
  
  {{docker}} volume rm field-tm_hanko_config

# Stop Field-TM & JOSM
[no-cd]
josm:
  {{docker}} compose \
    -f compose.yaml \
    -f contrib/josm/compose.yaml \
    down
  
# Stop Field-TM & tunnels
[no-cd]
tunnel:
  {{docker}} compose \
    -f compose.yaml \
    -f contrib/tunnel/compose.yaml \
    down

