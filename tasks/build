# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list build

# Build backend container
[no-cd]
all: backend

# Build backend container
[no-cd]
backend:
  # Consider caching
  # cache_to:
  #   - type=registry,ref=ghcr.io/hotosm/field-tm:${TAG_OVERRIDE:-debug}
  #   - type=gha
  # cache_from:
  #   - type=registry,ref=ghcr.io/hotosm/field-tm:${TAG_OVERRIDE:-debug}
  #   - type=gha
  COMPOSE_BAKE=true {{docker}} compose build backend

# Build backend development server container
[no-cd]
backend-dev:
  COMPOSE_BAKE=true \
  TARGET_OVERRIDE=prod TAG_OVERRIDE=dev \
    {{docker}} compose build --build-arg MONITORING=yes backend

# Set 'dc' alias for docker compose
alias:
  #!/usr/bin/env sh
  dc_alias_cmd="alias dc='docker compose'"
  if ! grep -q "$dc_alias_cmd" ~/.bashrc; then
      echo "Adding 'dc' alias to ~/.bashrc."
      echo "$dc_alias_cmd" | tee -a ~/.bashrc > /dev/null
  else
      echo "'dc' alias already exists in ~/.bashrc."
  fi
