#: app/htmx/setup_step_routes.py:82
msgid "Project not found or access denied."
msgstr "A kò rí iṣẹ́ náà tàbí a kọ ọ́ láàyè."

#: app/htmx/setup_step_routes.py:155
msgid ""
"Project finalisation failed. Please check your settings and try again. If"
" it continues, send the technical details below to your instance "
"administrator or support team."
msgstr ""
"Ìparí iṣẹ́ kuna. Jọwọ ṣàyẹ̀wò àwọn ètò rẹ kí o sì tún gbìyànjú. Tí ó bá ń"
" bá a lọ, fi àwọn àlàyé imọ̀ẹ̀rọ tó wà ní isalẹ ranṣẹ́ sí alabojuto "
"àpẹẹrẹ rẹ tàbí ẹgbẹ́ atilẹyin."

#: app/htmx/setup_step_routes.py:221
msgid "Invalid GeoJSON data in request. Please try uploading again."
msgstr "Data GeoJSON nínú ìbéèrè kò tọ́. Jọwọ tún gbé e sókè."

#: app/htmx/setup_step_routes.py:227
msgid "Error reading GeoJSON data from request."
msgstr "Aṣiṣe ṣẹlẹ nígbà tí a ń ka data GeoJSON láti inú ìbéèrè."

#: app/htmx/setup_step_routes.py:248
#, python-format
msgid ""
"Area is %(area_km2)s km², which exceeds the %(area_limit)s km² limit. "
"Please select a smaller area."
msgstr ""
"Agbègbè náà jẹ́ %(area_km2)s km², èyí tó ju ààlà %(area_limit)s km² lọ. "
"Jọwọ yan agbègbè tó kere síi."

#: app/htmx/setup_step_routes.py:256
#, python-format
msgid ""
"Area is %(area_km2)s km². Large areas (>%(area_warn)s km²) may take "
"longer to process. The data extract API is limited to 200 km²."
msgstr ""
"Agbègbè náà jẹ́ %(area_km2)s km². Àwọn agbègbè ńlá (>%(area_warn)s km²) "
"lè gba àkókò púpọ̀ síi láti ṣiṣẹ́. API ìyọkúrò data ní ààlà 200 km²."

#: app/htmx/setup_step_routes.py:321 app/htmx/setup_step_routes.py:766
msgid "Project AOI"
msgstr "AOI iṣẹ́"

#: app/htmx/setup_step_routes.py:334
#, python-format
msgid "Data Extract (%(data_feature_count)s features)"
msgstr "Ìyọkúrò data (%(data_feature_count)s àwọn ẹ̀yà)"

#: app/htmx/setup_step_routes.py:348
#, python-format
msgid "Task Boundaries (%(task_count)s tasks)"
msgstr "Ààlà iṣẹ́ (%(task_count)s iṣẹ́)"

#: app/htmx/setup_step_routes.py:384
msgid ""
"No task boundaries found. Please split the project into tasks first using"
" the \"Split AOI\" button above."
msgstr ""
"A kò rí ààlà iṣẹ́ kankan. Jọwọ kọ́kọ́ pín iṣẹ́ náà sí àwọn iṣẹ́ kéékèèké "
"pẹ̀lú bọtìnì \"Split AOI\" tó wà lókè."

#: app/htmx/setup_step_routes.py:440
#, python-format
msgid ""
"✓ AOI split successfully! Generated %(task_count)s task areas using "
"%(algorithm)s."
msgstr ""
"✓ A pín AOI ní àṣeyọrí! A ṣẹ̀dá agbègbè iṣẹ́ %(task_count)s pẹ̀lú "
"%(algorithm)s."

#: app/htmx/setup_step_routes.py:447
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries%(data_extract_info)s. Review "
"the results below. If satisfied, click \"Accept Task Choices\" to save. "
"Otherwise, adjust parameters above and click \"Split Again\" to "
"regenerate."
msgstr ""
"A ń fi ààlà iṣẹ́ %(task_count)s hàn%(data_extract_info)s. Ṣàyẹ̀wò àwọn "
"àbájáde tó wà ní isalẹ. Tí ó bá yọ ọ lójú, tẹ \"Accept Task Choices\" "
"láti fipamọ́. Bí kò bá rí bẹ́ẹ̀, ṣàtúnṣe àwọn ìwọn tó wà lókè kí o sì tẹ "
"\"Split Again\" láti tún ṣẹ̀dá a."

#: app/htmx/setup_step_routes.py:534 app/htmx/setup_step_routes.py:667
msgid "Data Extract"
msgstr "Ìyọkúrò data"

#: app/htmx/setup_step_routes.py:547
#, python-format
msgid "OSM data downloaded successfully! Found %(feature_count)s features."
msgstr "A gba data OSM wọlé ní àṣeyọrí! A rí %(feature_count)s àwọn ẹ̀yà."

#: app/htmx/setup_step_routes.py:550
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"downloading again with different parameters."
msgstr ""
"A ń fi %(feature_count)s àwọn ẹ̀yà hàn lórí maapu. Ṣàyẹ̀wò data tó wà ní "
"isalẹ. Tí ó bá yọ ọ lójú, tẹ \"Accept Data Extract\" láti fipamọ́. Bí kò "
"bá rí bẹ́ẹ̀, gbìyànjú láti tún ṣe igbasilẹ pẹ̀lú àwọn ìwọn mìíràn."

#: app/htmx/setup_step_routes.py:622
#: app/templates/partials/project_details/style_and_scripts.html:28
msgid "Invalid file type. Please upload a .geojson or .json file."
msgstr "Irú fáìlì kò tọ́. Jọwọ gbe fáìlì .geojson tàbí .json sókè."

#: app/htmx/setup_step_routes.py:647
msgid "No valid geometries found in GeoJSON."
msgstr "A kò rí àwọn geometry tó wulo nínú GeoJSON."

#: app/htmx/setup_step_routes.py:679
#, python-format
msgid "✓ GeoJSON uploaded successfully! Found %(feature_count)s features."
msgstr "✓ A gbe GeoJSON sókè ní àṣeyọrí! A rí %(feature_count)s àwọn ẹ̀yà."

#: app/htmx/setup_step_routes.py:682
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"uploading a different file."
msgstr ""
"A ń fi %(feature_count)s àwọn ẹ̀yà hàn lórí maapu. Ṣàyẹ̀wò data tó wà ní "
"isalẹ. Tí ó bá yọ ọ lójú, tẹ \"Accept Data Extract\" láti fipamọ́. Bí kò "
"bá rí bẹ́ẹ̀, gbìyànjú láti gbe fáìlì míì sókè."

#: app/htmx/setup_step_routes.py:742 app/htmx/setup_step_routes.py:915
msgid ""
"No GeoJSON data found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"A kò rí data GeoJSON kankan. Jọwọ gba data OSM wọlé tàbí gbe fáìlì "
"GeoJSON sókè kọ́kọ́."

#: app/htmx/setup_step_routes.py:778
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Ìyọkúrò data (%(feature_count)s àwọn ẹ̀yà)"

#: app/htmx/setup_step_routes.py:797
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"A ń fi %(feature_count)s àwọn ẹ̀yà data hàn lórí maapu. Ṣàyẹ̀wò data náà,"
" lẹ́yìn náà tẹ̀síwájú sí ìgbésẹ̀ tó kàn."

#: app/htmx/setup_step_routes.py:857
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ A ti yan ipo kíkó data tuntun nìkan. A foju kọ́ pínpín iṣẹ́, o sì lè "
"tẹ̀síwájú."

#: app/htmx/setup_step_routes.py:935
msgid ""
"✓ Data extract successfully saved! You can now proceed to Step 3 (upload "
"XLSForm) and then Step 4 (split tasks)."
msgstr ""
"✓ A ti fipamọ́ ìyọkúrò data ní àṣeyọrí! O lè lọ sí Ìgbésẹ̀ 3 (gbe XLSForm"
" sókè), lẹ́yìn náà sí Ìgbésẹ̀ 4 (pín iṣẹ́)."

#: app/htmx/setup_step_routes.py:1005
msgid ""
"No data extract found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"A kò rí ìyọkúrò data kankan. Jọwọ gba data OSM wọlé tàbí gbe fáìlì "
"GeoJSON sókè kọ́kọ́."

#: app/htmx/setup_step_routes.py:1036
#, python-format
msgid ""
"Previewing whole AOI (no splitting) with %(data_feature_count)s data "
"features. The entire AOI will be used as a single task."
msgstr ""
"A ń fi gbogbo AOI hàn (láìpín) pẹ̀lú %(data_feature_count)s àwọn ẹ̀yà "
"data. Gbogbo AOI náà ni a máa lò gẹ́gẹ́ bí iṣẹ́ kan ṣoṣo."

