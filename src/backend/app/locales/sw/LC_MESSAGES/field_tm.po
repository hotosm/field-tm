#: app/htmx/setup_step_routes.py:82
msgid "Project not found or access denied."
msgstr "Mradi haujapatikana au ruhusa imekataliwa."

#: app/htmx/setup_step_routes.py:155
msgid ""
"Project finalisation failed. Please check your settings and try again. If it"
" continues, send the technical details below to your instance administrator "
"or support team."
msgstr ""
"Ukamilishaji wa mradi umeshindikana. Tafadhali angalia mipangilio yako na "
"ujaribu tena. Iwapo tatizo litaendelea, tuma maelezo ya kiufundi hapa chini "
"kwa msimamizi wa mfumo wako au timu ya msaada."

#: app/htmx/setup_step_routes.py:221
msgid "Invalid GeoJSON data in request. Please try uploading again."
msgstr "Data ya GeoJSON si halali kwenye ombi. Tafadhali jaribu kupakia tena."

#: app/htmx/setup_step_routes.py:227
msgid "Error reading GeoJSON data from request."
msgstr "Hitilafu wakati wa kusoma data ya GeoJSON kutoka kwenye ombi."

#: app/htmx/setup_step_routes.py:248
#, python-format
msgid ""
"Area is %(area_km2)s km², which exceeds the %(area_limit)s km² limit. Please"
" select a smaller area."
msgstr ""
"Eneo ni %(area_km2)s km², ambalo limezidi kikomo cha %(area_limit)s km². "
"Tafadhali chagua eneo dogo zaidi."

#: app/htmx/setup_step_routes.py:256
#, python-format
msgid ""
"Area is %(area_km2)s km². Large areas (>%(area_warn)s km²) may take longer "
"to process. The data extract API is limited to 200 km²."
msgstr ""
"Eneo ni %(area_km2)s km². Maeneo makubwa (>%(area_warn)s km²) yanaweza "
"kuchukua muda mrefu kuchakatwa. API ya uchotaji data imewekewa kikomo cha "
"200 km²."

#: app/htmx/setup_step_routes.py:321 app/htmx/setup_step_routes.py:766
msgid "Project AOI"
msgstr "AOI ya mradi"

#: app/htmx/setup_step_routes.py:334
#, python-format
msgid "Data Extract (%(data_feature_count)s features)"
msgstr "Dondoo la data (%(data_feature_count)s vipengele)"

#: app/htmx/setup_step_routes.py:348
#, python-format
msgid "Task Boundaries (%(task_count)s tasks)"
msgstr "Mipaka ya kazi (%(task_count)s kazi)"

#: app/htmx/setup_step_routes.py:384
msgid ""
"No task boundaries found. Please split the project into tasks first using "
"the \"Split AOI\" button above."
msgstr ""
"Hakuna mipaka ya kazi iliyopatikana. Tafadhali gawanya mradi katika kazi "
"kwanza kwa kutumia kitufe cha \"Gawanya AOI\" hapo juu."

#: app/htmx/setup_step_routes.py:440
#, python-format
msgid ""
"✓ AOI split successfully! Generated %(task_count)s task areas using "
"%(algorithm)s."
msgstr ""
"✓ AOI imegawanywa kwa mafanikio! Maeneo ya kazi %(task_count)s yamezalishwa "
"kwa kutumia %(algorithm)s."

#: app/htmx/setup_step_routes.py:447
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries%(data_extract_info)s. Review the "
"results below. If satisfied, click \"Accept Task Choices\" to save. "
"Otherwise, adjust parameters above and click \"Split Again\" to regenerate."
msgstr ""
"Inaonyesha hakikisho la mipaka ya kazi %(task_count)s%(data_extract_info)s. "
"Kagua matokeo hapa chini. Ukiridhika, bofya \"Kubali machaguo ya kazi\" "
"kuhifadhi. Vinginevyo, rekebisha vigezo hapo juu na ubofye \"Gawanya tena\" "
"ili kuzalisha upya."

#: app/htmx/setup_step_routes.py:534 app/htmx/setup_step_routes.py:667
msgid "Data Extract"
msgstr "Dondoo la data"

#: app/htmx/setup_step_routes.py:547
#, python-format
msgid "OSM data downloaded successfully! Found %(feature_count)s features."
msgstr ""
"Data ya OSM imepakuliwa kwa mafanikio! Vipengele %(feature_count)s "
"vimepatikana."

#: app/htmx/setup_step_routes.py:550
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try downloading"
" again with different parameters."
msgstr ""
"Inaonyesha hakikisho la vipengele %(feature_count)s kwenye ramani. Kagua "
"data hapa chini. Ukiridhika, bofya \"Kubali dondoo la data\" kuhifadhi. "
"Vinginevyo, jaribu kupakua tena kwa vigezo tofauti."

#: app/htmx/setup_step_routes.py:622
#: app/templates/partials/project_details/style_and_scripts.html:28
msgid "Invalid file type. Please upload a .geojson or .json file."
msgstr "Aina ya faili si sahihi. Tafadhali pakia faili la .geojson au .json."

#: app/htmx/setup_step_routes.py:647
msgid "No valid geometries found in GeoJSON."
msgstr "Hakuna jiometri halali zilizopatikana kwenye GeoJSON."

#: app/htmx/setup_step_routes.py:679
#, python-format
msgid "✓ GeoJSON uploaded successfully! Found %(feature_count)s features."
msgstr "✓ GeoJSON imepakiwa kwa mafanikio! Vipengele %(feature_count)s vimepatikana."

#: app/htmx/setup_step_routes.py:682
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try uploading a"
" different file."
msgstr ""
"Inaonyesha hakikisho la vipengele %(feature_count)s kwenye ramani. Kagua "
"data hapa chini. Ukiridhika, bofya \"Kubali dondoo la data\" kuhifadhi. "
"Vinginevyo, jaribu kupakia faili tofauti."

#: app/htmx/setup_step_routes.py:742 app/htmx/setup_step_routes.py:915
msgid ""
"No GeoJSON data found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Hakuna data ya GeoJSON iliyopatikana. Tafadhali pakua data ya OSM au pakia "
"faili la GeoJSON kwanza."

#: app/htmx/setup_step_routes.py:778
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Dondoo la data (%(feature_count)s vipengele)"

#: app/htmx/setup_step_routes.py:797
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"Inaonyesha hakikisho la vipengele vya data %(feature_count)s kwenye ramani. "
"Kagua data, kisha endelea kwenye hatua inayofuata."

#: app/htmx/setup_step_routes.py:857
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ Hali ya kukusanya data mpya imechaguliwa. Mgawanyo wa kazi umerukwa na "
"unaweza kuendelea."

#: app/htmx/setup_step_routes.py:935
msgid ""
"✓ Data extract successfully saved! You can now proceed to Step 3 (upload "
"XLSForm) and then Step 4 (split tasks)."
msgstr ""
"✓ Dondoo la data limehifadhiwa kwa mafanikio! Sasa unaweza kuendelea na "
"Hatua ya 3 (pakia XLSForm) kisha Hatua ya 4 (gawanya kazi)."

#: app/htmx/setup_step_routes.py:1005
msgid ""
"No data extract found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Hakuna dondoo la data lililopatikana. Tafadhali pakua data ya OSM au pakia "
"faili la GeoJSON kwanza."

#: app/htmx/setup_step_routes.py:1036
#, python-format
msgid ""
"Previewing whole AOI (no splitting) with %(data_feature_count)s data "
"features. The entire AOI will be used as a single task."
msgstr ""
"Inaonyesha hakikisho la AOI yote (bila kugawanya) lenye vipengele vya data "
"%(data_feature_count)s. AOI yote itatumika kama kazi moja."

#: app/htmx/setup_step_routes.py:1043
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries and %(data_feature_count)s data "
"features together."
msgstr ""
"Inaonyesha hakikisho la mipaka ya kazi %(task_count)s na vipengele vya data "
"%(data_feature_count)s pamoja."

#: app/htmx/setup_step_routes.py:1102
msgid "Project outline not found. Cannot skip task splitting."
msgstr "Muhtasari wa mradi haukupatikana. Haiwezekani kuruka mgawanyo wa kazi."

#: app/htmx/setup_step_routes.py:1129
msgid ""
"✓ Task splitting skipped. The whole AOI will be used as a single task. You "
"can proceed to Step 4."
msgstr ""
"✓ Mgawanyo wa kazi umerukwa. AOI yote itatumika kama kazi moja. Unaweza "
"kuendelea hadi Hatua ya 4."

#: app/htmx/setup_step_routes.py:1190
msgid "Please select a splitting option."
msgstr "Tafadhali chagua chaguo la mgawanyo."

#: app/htmx/setup_step_routes.py:1210
msgid "✓ Task splitting is not required for this project setup."
msgstr "✓ Mgawanyo wa kazi hauhitajiki kwa mpangilio huu wa mradi."

#: app/htmx/setup_step_routes.py:1267
msgid "No data extract provided."
msgstr "Hakuna dondoo la data lililotolewa."

#: app/htmx/setup_step_routes.py:1271
msgid "Invalid data extract format."
msgstr "Muundo wa dondoo la data si sahihi."

#: app/htmx/setup_step_routes.py:1288
#, python-format
msgid ""
"✓ Data extract accepted! Saved %(feature_count)s features. Step 2 is now "
"complete."
msgstr ""
"✓ Dondoo la data limekubaliwa! Vipengele %(feature_count)s vimehifadhiwa. "
"Hatua ya 2 sasa imekamilika."

#: app/htmx/setup_step_routes.py:1338
msgid "No task areas data provided."
msgstr "Hakuna data ya maeneo ya kazi iliyotolewa."

#: app/htmx/setup_step_routes.py:1342
msgid "Invalid task areas data format."
msgstr "Muundo wa data ya maeneo ya kazi si sahihi."

#: app/htmx/setup_step_routes.py:1359
#: app/templates/partials/project_details/setup_steps.html:362
msgid "✓ Split tasks saved successfully"
msgstr "✓ Kazi zilizogawanywa zimehifadhiwa kwa mafanikio"

#: app/htmx/setup_step_routes.py:1414
msgid ""
"Provide ODK URL, username, and password (all 3), or leave them all blank to "
"use server defaults."
msgstr ""
"Toa URL ya ODK, jina la mtumiaji, na nywila (zote 3), au ziache zote wazi "
"ili kutumia chaguo-msingi za seva."

#: app/htmx/setup_step_routes.py:1536
msgid "GeoJSON is required"
msgstr "GeoJSON inahitajika"

#: app/htmx/setup_step_routes.py:1547
msgid "No polygon geometries found. Project area must be a polygon."
msgstr ""
"Hakuna jiometri za poligoni zilizopatikana. Eneo la mradi lazima liwe "
"poligoni."

