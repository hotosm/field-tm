#: app/templates/landing.html:624
msgid ""
"Monitor survey progress at task and feature level so managers can make "
"informed\n"
"          decisions quickly."
msgstr ""
"Lelee ọganihu nyocha n'ọkwa ọrụ na njirimara ka ndị njikwa nwee ike ime "
"mkpebi mara mma ngwa ngwa."

