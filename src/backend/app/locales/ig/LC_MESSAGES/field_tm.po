msgstr ""
"A hụghị data GeoJSON. Biko budata data OSM ma ọ bụ bulite faịlụ GeoJSON "
"mbụ."

#: app/htmx/setup_step_routes.py:791
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Mgbakwunye data (%(feature_count)s njirimara)"

#: app/htmx/setup_step_routes.py:810
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"A na-elele njirimara data %(feature_count)s n'elu maapụ. Nyochaa data "
"ahụ, wee gaa n'ihu na nzọụkwụ ọzọ."

#: app/htmx/setup_step_routes.py:870
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ A họrọ ọnọdụ ịnakọta data ọhụrụ. A gafere nkewa ọrụ ma ị nwere ike ịga "
"n'ihu."

