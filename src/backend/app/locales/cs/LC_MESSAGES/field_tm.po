#: app/htmx/setup_step_routes.py:155
msgid ""
"Project finalisation failed. Please check your settings and try again. If"
" it continues, send the technical details below to your instance "
"administrator or support team."
msgstr ""
"Dokončení projektu se nezdařilo. Zkontrolujte nastavení a zkuste to "
"znovu. Pokud problém přetrvá, pošlete níže uvedené technické podrobnosti "
"správci instance nebo týmu podpory."

#: app/htmx/setup_step_routes.py:221
msgid "Invalid GeoJSON data in request. Please try uploading again."
msgstr "V požadavku jsou neplatná data GeoJSON. Zkuste nahrání znovu."

#: app/htmx/setup_step_routes.py:227
msgid "Error reading GeoJSON data from request."
msgstr "Chyba při čtení dat GeoJSON z požadavku."

#: app/htmx/setup_step_routes.py:248
#, python-format
msgid ""
"Area is %(area_km2)s km², which exceeds the %(area_limit)s km² limit. "
"Please select a smaller area."
msgstr ""
"Oblast má %(area_km2)s km², což překračuje limit %(area_limit)s km². "
"Vyberte menší oblast."

#: app/htmx/setup_step_routes.py:256
#, python-format
msgid ""
"Area is %(area_km2)s km². Large areas (>%(area_warn)s km²) may take "
"longer to process. The data extract API is limited to 200 km²."
msgstr ""
"Oblast má %(area_km2)s km². Zpracování velkých oblastí (>%(area_warn)s "
"km²) může trvat déle. API pro extrakci dat je omezeno na 200 km²."

#: app/htmx/setup_step_routes.py:321 app/htmx/setup_step_routes.py:766
msgid "Project AOI"
msgstr "AOI projektu"

#: app/htmx/setup_step_routes.py:334
#, python-format
msgid "Data Extract (%(data_feature_count)s features)"
msgstr "Datový výřez (%(data_feature_count)s prvků)"

#: app/htmx/setup_step_routes.py:348
#, python-format
msgid "Task Boundaries (%(task_count)s tasks)"
msgstr "Hranice úkolů (%(task_count)s úkolů)"

#: app/htmx/setup_step_routes.py:384
msgid ""
"No task boundaries found. Please split the project into tasks first using"
" the \"Split AOI\" button above."
msgstr ""
"Nebyly nalezeny žádné hranice úkolů. Nejprve rozdělte projekt na úkoly "
"pomocí tlačítka „Rozdělit AOI“ výše."

#: app/htmx/setup_step_routes.py:440
#, python-format
msgid ""
"✓ AOI split successfully! Generated %(task_count)s task areas using "
"%(algorithm)s."
msgstr ""
"✓ AOI byla úspěšně rozdělena! Pomocí %(algorithm)s bylo vytvořeno "
"%(task_count)s oblastí úkolů."

#: app/htmx/setup_step_routes.py:447
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries%(data_extract_info)s. Review "
"the results below. If satisfied, click \"Accept Task Choices\" to save. "
"Otherwise, adjust parameters above and click \"Split Again\" to "
"regenerate."
msgstr ""
"Zobrazuje se náhled %(task_count)s hranic úkolů%(data_extract_info)s. "
"Zkontrolujte výsledky níže. Pokud jste spokojeni, klikněte na „Přijmout "
"volby úkolů“ pro uložení. Jinak upravte parametry výše a klikněte na "
"„Rozdělit znovu“ pro nové vygenerování."

#: app/htmx/setup_step_routes.py:534 app/htmx/setup_step_routes.py:667
msgid "Data Extract"
msgstr "Datový výřez"

#: app/htmx/setup_step_routes.py:547
#, python-format
msgid "OSM data downloaded successfully! Found %(feature_count)s features."
msgstr "Data OSM byla úspěšně stažena! Nalezeno %(feature_count)s prvků."

#: app/htmx/setup_step_routes.py:550
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"downloading again with different parameters."
msgstr ""
"Zobrazuje se náhled %(feature_count)s prvků na mapě. Zkontrolujte data "
"níže. Pokud jste spokojeni, klikněte na „Přijmout datový výřez“ pro "
"uložení. Jinak zkuste stahování znovu s jinými parametry."

#: app/htmx/setup_step_routes.py:622
#: app/templates/partials/project_details/style_and_scripts.html:28
msgid "Invalid file type. Please upload a .geojson or .json file."
msgstr "Neplatný typ souboru. Nahrajte soubor .geojson nebo .json."

#: app/htmx/setup_step_routes.py:647
msgid "No valid geometries found in GeoJSON."
msgstr "V GeoJSON nebyly nalezeny žádné platné geometrie."

#: app/htmx/setup_step_routes.py:679
#, python-format
msgid "✓ GeoJSON uploaded successfully! Found %(feature_count)s features."
msgstr "✓ GeoJSON bylo úspěšně nahráno! Nalezeno %(feature_count)s prvků."

#: app/htmx/setup_step_routes.py:682
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"uploading a different file."
msgstr ""
"Zobrazuje se náhled %(feature_count)s prvků na mapě. Zkontrolujte data "
"níže. Pokud jste spokojeni, klikněte na „Přijmout datový výřez“ pro "
"uložení. Jinak zkuste nahrát jiný soubor."

#: app/htmx/setup_step_routes.py:742 app/htmx/setup_step_routes.py:915
msgid ""
"No GeoJSON data found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Nebyla nalezena žádná data GeoJSON. Nejprve stáhněte data OSM nebo "
"nahrajte soubor GeoJSON."

#: app/htmx/setup_step_routes.py:778
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Datový výřez (%(feature_count)s prvků)"

#: app/htmx/setup_step_routes.py:797
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"Zobrazuje se náhled %(feature_count)s datových prvků na mapě. "
"Zkontrolujte data a poté pokračujte na další krok."

#: app/htmx/setup_step_routes.py:857
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ Byl vybrán režim sběru nových dat. Rozdělení úkolů je přeskočeno a "
"můžete pokračovat."

#: app/htmx/setup_step_routes.py:935
msgid ""
"✓ Data extract successfully saved! You can now proceed to Step 3 (upload "
"XLSForm) and then Step 4 (split tasks)."
msgstr ""
"✓ Datový výřez byl úspěšně uložen! Nyní můžete pokračovat na Krok 3 "
"(nahrání XLSForm) a poté na Krok 4 (rozdělení úkolů)."

#: app/htmx/setup_step_routes.py:1005
msgid ""
"No data extract found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Nebyl nalezen žádný datový výřez. Nejprve stáhněte data OSM nebo nahrajte"
" soubor GeoJSON."

#: app/htmx/setup_step_routes.py:1036
#, python-format
msgid ""
"Previewing whole AOI (no splitting) with %(data_feature_count)s data "
"features. The entire AOI will be used as a single task."
msgstr ""
"Zobrazuje se náhled celé AOI (bez rozdělení) s %(data_feature_count)s "
"datovými prvky. Celá AOI bude použita jako jeden úkol."

#: app/htmx/setup_step_routes.py:1043
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries and %(data_feature_count)s data"
" features together."
msgstr ""
"Zobrazuje se náhled %(task_count)s hranic úkolů a %(data_feature_count)s "
"datových prvků dohromady."

#: app/htmx/setup_step_routes.py:1102
msgid "Project outline not found. Cannot skip task splitting."
msgstr "Obrys projektu nebyl nalezen. Rozdělení úkolů nelze přeskočit."

#: app/htmx/setup_step_routes.py:1129
msgid ""
"✓ Task splitting skipped. The whole AOI will be used as a single task. "
"You can proceed to Step 4."
msgstr ""
"✓ Rozdělení úkolů bylo přeskočeno. Celá AOI bude použita jako jeden úkol."
" Můžete pokračovat na Krok 4."

#: app/htmx/setup_step_routes.py:1190
msgid "Please select a splitting option."
msgstr "Vyberte možnost rozdělení."

#: app/htmx/setup_step_routes.py:1210
msgid "✓ Task splitting is not required for this project setup."
msgstr "✓ Pro toto nastavení projektu není rozdělení úkolů vyžadováno."

#: app/htmx/setup_step_routes.py:1267
msgid "No data extract provided."
msgstr "Nebyl poskytnut žádný datový výřez."

#: app/htmx/setup_step_routes.py:1271
msgid "Invalid data extract format."
msgstr "Neplatný formát datového výřezu."

#: app/htmx/setup_step_routes.py:1288
#, python-format
msgid ""
"✓ Data extract accepted! Saved %(feature_count)s features. Step 2 is now "
"complete."
msgstr ""
"✓ Datový výřez byl přijat! Uloženo %(feature_count)s prvků. Krok 2 je "
"nyní dokončen."

#: app/htmx/setup_step_routes.py:1338
msgid "No task areas data provided."
msgstr "Nebyla poskytnuta žádná data oblastí úkolů."

#: app/htmx/setup_step_routes.py:1342
msgid "Invalid task areas data format."
msgstr "Neplatný formát dat oblastí úkolů."

#: app/htmx/setup_step_routes.py:1359
#: app/templates/partials/project_details/setup_steps.html:362
msgid "✓ Split tasks saved successfully"
msgstr "✓ Rozdělené úkoly byly úspěšně uloženy"

#: app/htmx/setup_step_routes.py:1414
msgid ""
"Provide ODK URL, username, and password (all 3), or leave them all blank "
"to use server defaults."
msgstr ""
"Zadejte URL ODK, uživatelské jméno a heslo (všechny 3), nebo je všechny "
"ponechte prázdné pro použití výchozího nastavení serveru."

#: app/htmx/setup_step_routes.py:1536
msgid "GeoJSON is required"
msgstr "GeoJSON je povinné"

#: app/htmx/setup_step_routes.py:1547
msgid "No polygon geometries found. Project area must be a polygon."
msgstr ""
"Nebyly nalezeny žádné polygonové geometrie. Oblast projektu musí být "
"polygon."

