#: app/templates/new_project.html:4
msgid "Create New Project"
msgstr "Crea nuovo progetto"

#: app/templates/new_project.html:17
msgid ""
"If you are collecting OSM Buildings, use the simple workflow with AOI "
"only."
msgstr ""
"Se stai raccogliendo dati OSM Buildings, usa il flusso semplificato solo "
"con AOI."

#: app/templates/new_project.html:45
msgid "Project Name"
msgstr "Nome del progetto"

#: app/templates/new_project.html:50
msgid "Enter project name"
msgstr "Inserisci il nome del progetto"

#: app/templates/new_project.html:63
msgid "Enter project description"
msgstr "Inserisci la descrizione del progetto"

#: app/templates/new_project.html:72
msgid "Field Mapping App"
msgstr "App di mappatura sul campo"

#: app/templates/new_project.html:113 app/templates/project_details.html:95
msgid "Hashtags"
msgstr "Hashtag"

#: app/templates/new_project.html:116
msgid "Type hashtags and press Enter or comma"
msgstr "Digita hashtag e premi Invio o virgola"

#: app/templates/new_project.html:121
msgid ""
"Type hashtags and press Enter or comma to add them. Click the × on a tag "
"to remove\n"
"          it."
msgstr ""
"Digita hashtag e premi Invio o virgola per aggiungerli. Fai clic sulla × "
"di un tag per rimuoverlo."

#: app/templates/new_project.html:131
msgid "Creating..."
msgstr "Creazione in corso..."

#: app/templates/new_project.html:141
msgid "Something went wrong. Please try again."
msgstr "Qualcosa è andato storto. Riprova."

#: app/templates/new_project.html:264
msgid "A project with this name already exists. Please choose a different name."
msgstr "Esiste già un progetto con questo nome. Scegli un nome diverso."

#: app/templates/new_project.html:349
msgid "Description is required."
msgstr "La descrizione è obbligatoria."

#: app/templates/new_project_simple.html:8
msgid ""
"This simple flow only needs your project area. We will auto-generate the "
"project title,\n"
"      description, and tags for OSM Buildings."
msgstr ""
"Questo flusso semplificato richiede solo l’area del progetto. Genereremo "
"automaticamente il titolo, la descrizione e i tag del progetto per OSM "
"Buildings."

#: app/templates/new_project_simple.html:38
msgid "Back to Standard Form"
msgstr "Torna al modulo standard"

