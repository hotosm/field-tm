msgstr ""
"Ipinapakita ang preview ng %(task_count)s hangganan ng gawain at "
"%(data_feature_count)s data feature nang magkasama."

#: app/htmx/setup_step_routes.py:1115
msgid "Project outline not found. Cannot skip task splitting."
msgstr ""
"Hindi nahanap ang outline ng proyekto. Hindi maaaring laktawan ang "
"paghahati ng gawain."

#: app/htmx/setup_step_routes.py:1142
msgid ""
"✓ Task splitting skipped. The whole AOI will be used as a single task. "
"You can proceed to Step 5."
msgstr ""
"✓ Nilaktawan ang paghahati ng gawain. Gagamitin ang buong AOI bilang "
