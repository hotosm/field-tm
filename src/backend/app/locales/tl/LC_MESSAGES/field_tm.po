msgstr "Nagkaroon ng error sa pagbabasa ng GeoJSON data mula sa request."

#: app/htmx/setup_step_routes.py:252
#, python-format
msgid ""
"Area is %(area_km2)s km², which exceeds the %(area_limit)s km² limit. "
"Please select a smaller area."
msgstr ""
"Ang lawak ay %(area_km2)s km², na lumalampas sa limitasyong "
"%(area_limit)s km². Mangyaring pumili ng mas maliit na lugar."

#: app/htmx/setup_step_routes.py:260
#, python-format
msgid ""
"Area is %(area_km2)s km². Large areas (>%(area_warn)s km²) may take "
"longer to process. The data extract API is limited to 200 km²."
msgstr ""
"Ang lawak ay %(area_km2)s km². Ang malalaking lugar (>%(area_warn)s km²) "
"ay maaaring mas matagal iproseso. Ang data extract API ay limitado sa 200"
" km²."

