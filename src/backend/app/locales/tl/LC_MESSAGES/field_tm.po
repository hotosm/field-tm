"feature."

#: app/htmx/setup_step_routes.py:695
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"uploading a different file."
msgstr ""
"Ipinapakita ang preview ng %(feature_count)s feature sa mapa. Suriin ang "
"data sa ibaba. Kung ayos na, i-click ang \"Accept Data Extract\" para "
"i-save. Kung hindi, subukang mag-upload ng ibang file."

#: app/htmx/setup_step_routes.py:755 app/htmx/setup_step_routes.py:928
msgid ""
"No GeoJSON data found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Walang nahanap na GeoJSON data. Pakidownload muna ang OSM data o mag-"
"upload muna ng GeoJSON file."

#: app/htmx/setup_step_routes.py:791
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Data Extract (%(feature_count)s feature)"

#: app/htmx/setup_step_routes.py:810
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"Ipinapakita ang preview ng %(feature_count)s data feature sa mapa. Suriin"
" ang data, pagkatapos ay magpatuloy sa susunod na hakbang."

#: app/htmx/setup_step_routes.py:870
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ Napili ang collect-new-data mode. Lalaktawan ang paghahati ng gawain at"
" maaari ka nang magpatuloy."

