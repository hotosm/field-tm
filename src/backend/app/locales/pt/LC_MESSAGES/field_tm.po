msgid ""
"✓ Data extract successfully saved! You can now proceed to Step 3 (upload "
"XLSForm) and then Step 4 (split tasks)."
msgstr ""
"✓ Extração de dados salva com sucesso! Agora você pode prosseguir para o "
"Passo 3 (enviar XLSForm) e depois o Passo 4 (dividir tarefas)."

#: app/htmx/setup_step_routes.py:1005
msgid ""
"No data extract found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Nenhuma extração de dados encontrada. Primeiro baixe dados OSM ou envie "
"um arquivo GeoJSON."

#: app/htmx/setup_step_routes.py:1036
#, python-format
msgid ""
"Previewing whole AOI (no splitting) with %(data_feature_count)s data "
"features. The entire AOI will be used as a single task."
msgstr ""
"Visualizando toda a área de interesse (sem divisão) com "
"%(data_feature_count)s elementos de dados. Toda a área de interesse será "
"usada como uma única tarefa."

#: app/htmx/setup_step_routes.py:1043
#, python-format
