#: app/templates/landing.html:558
msgid "Coordinate field campaigns"
msgstr "Coordenar campanhas de campo"

#: app/templates/landing.html:561
msgid ""
"Enhancing field mapping efficiency and accuracy through seamless "
"coordination."
msgstr ""
"Melhorando a eficiência e precisão do mapeamento de campo por meio de "
"coordenação fluida."

#: app/templates/landing.html:564
