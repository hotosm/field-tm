msgstr ""
"Visualizando %(task_count)s limites de tarefas e %(data_feature_count)s "
"elementos de dados juntos."

#: app/htmx/setup_step_routes.py:1102
msgid "Project outline not found. Cannot skip task splitting."
msgstr ""
"Contorno do projeto não encontrado. Não é possível pular a divisão de "
"tarefas."

#: app/htmx/setup_step_routes.py:1129
msgid ""
"✓ Task splitting skipped. The whole AOI will be used as a single task. "
"You can proceed to Step 4."
msgstr ""
"✓ Divisão de tarefas pulada. Toda a área de interesse será usada como uma"
" única tarefa. Você pode prosseguir para o Passo 4."

#: app/htmx/setup_step_routes.py:1190
msgid "Please select a splitting option."
msgstr "Selecione uma opção de divisão."

#: app/htmx/setup_step_routes.py:1210
msgid "✓ Task splitting is not required for this project setup."
msgstr "✓ A divisão de tarefas não é necessária para esta configuração do projeto."

#: app/htmx/setup_step_routes.py:1267
