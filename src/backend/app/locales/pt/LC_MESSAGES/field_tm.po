msgstr ""
"A área é %(area_km2)s km². Áreas grandes (>%(area_warn)s km²) podem levar"
" mais tempo para processar. A API de extração de dados é limitada a 200 "
"km²."

#: app/htmx/setup_step_routes.py:321 app/htmx/setup_step_routes.py:766
msgid "Project AOI"
msgstr "Área de interesse do projeto"

#: app/htmx/setup_step_routes.py:334
#, python-format
msgid "Data Extract (%(data_feature_count)s features)"
msgstr "Extração de dados (%(data_feature_count)s elementos)"

#: app/htmx/setup_step_routes.py:348
#, python-format
msgid "Task Boundaries (%(task_count)s tasks)"
msgstr "Limites de tarefas (%(task_count)s tarefas)"

#: app/htmx/setup_step_routes.py:384
msgid ""
"No task boundaries found. Please split the project into tasks first using"
" the \"Split AOI\" button above."
msgstr ""
"Nenhum limite de tarefa encontrado. Primeiro divida o projeto em tarefas "
"usando o botão \"Dividir área de interesse\" acima."

#: app/htmx/setup_step_routes.py:440
#, python-format
msgid ""
"✓ AOI split successfully! Generated %(task_count)s task areas using "
"%(algorithm)s."
msgstr ""
"✓ Área de interesse dividida com sucesso! %(task_count)s áreas de tarefas"
" geradas usando %(algorithm)s."

#: app/htmx/setup_step_routes.py:447
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries%(data_extract_info)s. Review "
"the results below. If satisfied, click \"Accept Task Choices\" to save. "
"Otherwise, adjust parameters above and click \"Split Again\" to "
"regenerate."
msgstr ""
"Visualizando %(task_count)s limites de tarefas%(data_extract_info)s. "
"Revise os resultados abaixo. Se satisfeito, clique em \"Aceitar escolhas "
"de tarefas\" para salvar. Caso contrário, ajuste os parâmetros acima e "
"clique em \"Dividir novamente\" para regenerar."

#: app/htmx/setup_step_routes.py:534 app/htmx/setup_step_routes.py:667
msgid "Data Extract"
msgstr "Extração de dados"

#: app/htmx/setup_step_routes.py:547
#, python-format
msgid "OSM data downloaded successfully! Found %(feature_count)s features."
msgstr "Dados OSM baixados com sucesso! %(feature_count)s elementos encontrados."

#: app/htmx/setup_step_routes.py:550
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"downloading again with different parameters."
msgstr ""
"Visualizando %(feature_count)s elementos no mapa. Revise os dados abaixo."
" Se satisfeito, clique em \"Aceitar extração de dados\" para salvar. Caso"
" contrário, tente baixar novamente com parâmetros diferentes."

#: app/htmx/setup_step_routes.py:622
#: app/templates/partials/project_details/style_and_scripts.html:28
msgid "Invalid file type. Please upload a .geojson or .json file."
msgstr "Tipo de arquivo inválido. Envie um arquivo .geojson ou .json."

#: app/htmx/setup_step_routes.py:647
msgid "No valid geometries found in GeoJSON."
msgstr "Nenhuma geometria válida encontrada no GeoJSON."

#: app/htmx/setup_step_routes.py:679
#, python-format
