msgstr ""
"Nenhum dado GeoJSON encontrado. Primeiro baixe dados OSM ou envie um "
"arquivo GeoJSON."

#: app/htmx/setup_step_routes.py:778
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Extração de dados (%(feature_count)s elementos)"

#: app/htmx/setup_step_routes.py:797
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"Visualizando %(feature_count)s elementos de dados no mapa. Revise os "
"dados e continue para o próximo passo."

#: app/htmx/setup_step_routes.py:857
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ Modo de coleta de novos dados selecionado. A divisão de tarefas é "
"pulada e você pode continuar."

