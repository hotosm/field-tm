#: app/htmx/setup_step_routes.py:156
msgid ""
"Project finalisation failed. Please check your settings and try again. If"
" it continues, send the technical details below to your instance "
"administrator or support team."
msgstr ""
"Finalisasi proyek gagal. Silakan periksa pengaturan Anda dan coba lagi. "
"Jika masih berlanjut, kirimkan rincian teknis di bawah ini kepada "
"administrator instans atau tim dukungan Anda."

#: app/htmx/setup_step_routes.py:225
msgid "Invalid GeoJSON data in request. Please try uploading again."
msgstr "Data GeoJSON dalam permintaan tidak valid. Silakan coba unggah lagi."

#: app/htmx/setup_step_routes.py:231
msgid "Error reading GeoJSON data from request."
msgstr "Kesalahan saat membaca data GeoJSON dari permintaan."

#: app/htmx/setup_step_routes.py:252
#, python-format
msgid ""
"Area is %(area_km2)s km², which exceeds the %(area_limit)s km² limit. "
"Please select a smaller area."
msgstr ""
"Luas area adalah %(area_km2)s km², melebihi batas %(area_limit)s km². "
"Silakan pilih area yang lebih kecil."

#: app/htmx/setup_step_routes.py:260
#, python-format
msgid ""
"Area is %(area_km2)s km². Large areas (>%(area_warn)s km²) may take "
"longer to process. The data extract API is limited to 200 km²."
msgstr ""
"Luas area adalah %(area_km2)s km². Area besar (>%(area_warn)s km²) "
"mungkin membutuhkan waktu lebih lama untuk diproses. API ekstrak data "
"dibatasi hingga 200 km²."

#: app/htmx/setup_step_routes.py:326 app/htmx/setup_step_routes.py:779
msgid "Project AOI"
msgstr "AOI Proyek"

#: app/htmx/setup_step_routes.py:339
#, python-format
msgid "Data Extract (%(data_feature_count)s features)"
msgstr "Ekstrak Data (%(data_feature_count)s fitur)"

#: app/htmx/setup_step_routes.py:353
#, python-format
msgid "Task Boundaries (%(task_count)s tasks)"
msgstr "Batas Tugas (%(task_count)s tugas)"

#: app/htmx/setup_step_routes.py:362
msgid "Task ID"
msgstr "ID Tugas"

#: app/htmx/setup_step_routes.py:363
msgid "Building Count"
msgstr "Jumlah Bangunan"

#: app/htmx/setup_step_routes.py:397
msgid ""
"No task boundaries found. Please split the project into tasks first using"
" the \"Split AOI\" button above."
msgstr ""
"Tidak ditemukan batas tugas. Silakan bagi proyek menjadi tugas terlebih "
"dahulu menggunakan tombol \"Split AOI\" di atas."

#: app/htmx/setup_step_routes.py:453
#, python-format
msgid ""
"✓ AOI split successfully! Generated %(task_count)s task areas using "
"%(algorithm)s."
msgstr ""
"✓ AOI berhasil dibagi! Menghasilkan %(task_count)s area tugas menggunakan"
" %(algorithm)s."

#: app/htmx/setup_step_routes.py:460
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries%(data_extract_info)s. Review "
"the results below. If satisfied, click \"Accept Task Choices\" to save. "
"Otherwise, adjust parameters above and click \"Split Again\" to "
"regenerate."
msgstr ""
"Menampilkan pratinjau %(task_count)s batas tugas%(data_extract_info)s. "
"Tinjau hasil di bawah. Jika sesuai, klik \"Accept Task Choices\" untuk "
"menyimpan. Jika tidak, sesuaikan parameter di atas dan klik \"Split "
"Again\" untuk membuat ulang."

#: app/htmx/setup_step_routes.py:547 app/htmx/setup_step_routes.py:680
msgid "Data Extract"
msgstr "Ekstrak Data"

#: app/htmx/setup_step_routes.py:560
#, python-format
msgid "OSM data downloaded successfully! Found %(feature_count)s features."
msgstr "Data OSM berhasil diunduh! Ditemukan %(feature_count)s fitur."

#: app/htmx/setup_step_routes.py:563
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"downloading again with different parameters."
msgstr ""
"Menampilkan pratinjau %(feature_count)s fitur di peta. Tinjau data di "
"bawah. Jika sesuai, klik \"Accept Data Extract\" untuk menyimpan. Jika "
"tidak, coba unduh lagi dengan parameter berbeda."

#: app/htmx/setup_step_routes.py:635
#: app/templates/partials/project_details/style_and_scripts.html:28
msgid "Invalid file type. Please upload a .geojson or .json file."
msgstr "Jenis file tidak valid. Silakan unggah file .geojson atau .json."

#: app/htmx/setup_step_routes.py:660
msgid "No valid geometries found in GeoJSON."
msgstr "Tidak ditemukan geometri yang valid di GeoJSON."

#: app/htmx/setup_step_routes.py:692
#, python-format
msgid "✓ GeoJSON uploaded successfully! Found %(feature_count)s features."
msgstr "✓ GeoJSON berhasil diunggah! Ditemukan %(feature_count)s fitur."

#: app/htmx/setup_step_routes.py:695
#, python-format
msgid ""
"Previewing %(feature_count)s features on map. Review the data below. If "
"satisfied, click \"Accept Data Extract\" to save. Otherwise, try "
"uploading a different file."
msgstr ""
"Menampilkan pratinjau %(feature_count)s fitur di peta. Tinjau data di "
"bawah. Jika sesuai, klik \"Accept Data Extract\" untuk menyimpan. Jika "
"tidak, coba unggah file lain."

#: app/htmx/setup_step_routes.py:755 app/htmx/setup_step_routes.py:928
msgid ""
"No GeoJSON data found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Tidak ditemukan data GeoJSON. Silakan unduh data OSM atau unggah file "
"GeoJSON terlebih dahulu."

#: app/htmx/setup_step_routes.py:791
#, python-format
msgid "Data Extract (%(feature_count)s features)"
msgstr "Ekstrak Data (%(feature_count)s fitur)"

#: app/htmx/setup_step_routes.py:810
#, python-format
msgid ""
"Previewing %(feature_count)s data features on map. Review the data, then "
"continue to the next step."
msgstr ""
"Menampilkan pratinjau %(feature_count)s fitur data di peta. Tinjau data, "
"lalu lanjutkan ke langkah berikutnya."

#: app/htmx/setup_step_routes.py:870
msgid ""
"✓ Collect-new-data mode selected. Task splitting is skipped and you can "
"continue."
msgstr ""
"✓ Mode kumpulkan data baru dipilih. Pembagian tugas dilewati dan Anda "
"dapat melanjutkan."

#: app/htmx/setup_step_routes.py:948
msgid ""
"✓ Data extract successfully saved! You can now proceed to Step 4 (split "
"tasks)."
msgstr ""

#: app/htmx/setup_step_routes.py:1018
msgid ""
"No data extract found. Please download OSM data or upload a GeoJSON file "
"first."
msgstr ""
"Tidak ditemukan ekstrak data. Silakan unduh data OSM atau unggah file "
"GeoJSON terlebih dahulu."

#: app/htmx/setup_step_routes.py:1049
#, python-format
msgid ""
"Previewing whole AOI (no splitting) with %(data_feature_count)s data "
"features. The entire AOI will be used as a single task."
msgstr ""
"Menampilkan pratinjau seluruh AOI (tanpa pembagian) dengan "
"%(data_feature_count)s fitur data. Seluruh AOI akan digunakan sebagai "
"satu tugas."

#: app/htmx/setup_step_routes.py:1056
#, python-format
msgid ""
"Previewing %(task_count)s task boundaries and %(data_feature_count)s data"
" features together."
msgstr ""
"Menampilkan pratinjau %(task_count)s batas tugas dan "
"%(data_feature_count)s fitur data bersama-sama."

#: app/htmx/setup_step_routes.py:1115
msgid "Project outline not found. Cannot skip task splitting."
msgstr "Batas proyek tidak ditemukan. Tidak dapat melewati pembagian tugas."

#: app/htmx/setup_step_routes.py:1142
msgid ""
"✓ Task splitting skipped. The whole AOI will be used as a single task. "
"You can proceed to Step 5."
msgstr ""
"✓ Pembagian tugas dilewati. Seluruh AOI akan digunakan sebagai satu "
"tugas. Anda dapat melanjutkan ke Langkah 5."

#: app/htmx/setup_step_routes.py:1204
msgid "Please select a splitting option."
msgstr "Silakan pilih opsi pembagian."

#: app/htmx/setup_step_routes.py:1225
msgid "✓ Task splitting is not required for this project setup."
msgstr "✓ Pembagian tugas tidak diperlukan untuk pengaturan proyek ini."

#: app/htmx/setup_step_routes.py:1282
msgid "No data extract provided."
msgstr "Tidak ada ekstrak data yang diberikan."

#: app/htmx/setup_step_routes.py:1286
msgid "Invalid data extract format."
msgstr "Format ekstrak data tidak valid."

#: app/htmx/setup_step_routes.py:1303
#, python-format
msgid ""
"✓ Data extract accepted! Saved %(feature_count)s features. Step 2 is now "
"complete."
msgstr ""
"✓ Ekstrak data diterima! %(feature_count)s fitur disimpan. Langkah 2 "
"sekarang selesai."

#: app/htmx/setup_step_routes.py:1353
msgid "No task areas data provided."
msgstr "Tidak ada data area tugas yang diberikan."

#: app/htmx/setup_step_routes.py:1357
msgid "Invalid task areas data format."
msgstr "Format data area tugas tidak valid."

#: app/htmx/setup_step_routes.py:1374
#: app/templates/partials/project_details/setup_steps.html:455
msgid "✓ Split tasks saved successfully"
msgstr "✓ Tugas yang dibagi berhasil disimpan"

#: app/htmx/setup_step_routes.py:1429
msgid ""
"Provide ODK URL, username, and password (all 3), or leave them all blank "
"to use server defaults."
msgstr ""
"Berikan URL ODK, nama pengguna, dan kata sandi (ketiganya), atau biarkan "
"kosong untuk menggunakan bawaan server."

#: app/htmx/setup_step_routes.py:1551
msgid "GeoJSON is required"
msgstr "GeoJSON diperlukan"

#: app/htmx/setup_step_routes.py:1562
